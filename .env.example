# =============================================================================
# BarApp - Variables de entorno (Claves sensibles)
# =============================================================================
# Copia este archivo a .env y rellena con tus claves reales.
# El archivo .env NUNCA debe subirse a Git (está en .gitignore).
#
# Cómo obtener las claves:
# - Google Maps: https://console.cloud.google.com/apis/credentials
# - Firebase: Ejecuta `dart run flutterfire_cli:flutterfire configure`
# =============================================================================

# --- Google Maps API Key (Web, Android, iOS) ---
GOOGLE_MAPS_API_KEY=TU_GOOGLE_MAPS_API_KEY

# --- Firebase Web ---
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=

# --- Firebase Android ---
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_ANDROID_PROJECT_ID=
FIREBASE_ANDROID_STORAGE_BUCKET=
FIREBASE_ANDROID_MESSAGING_SENDER_ID=

# --- Firebase iOS ---
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_PROJECT_ID=
FIREBASE_IOS_STORAGE_BUCKET=
FIREBASE_IOS_MESSAGING_SENDER_ID=
FIREBASE_IOS_ANDROID_CLIENT_ID=
FIREBASE_IOS_IOS_CLIENT_ID=
FIREBASE_IOS_BUNDLE_ID=

# --- Firebase macOS ---
FIREBASE_MACOS_API_KEY=
FIREBASE_MACOS_APP_ID=
FIREBASE_MACOS_PROJECT_ID=
FIREBASE_MACOS_STORAGE_BUCKET=
FIREBASE_MACOS_MESSAGING_SENDER_ID=
FIREBASE_MACOS_ANDROID_CLIENT_ID=
FIREBASE_MACOS_IOS_CLIENT_ID=
FIREBASE_MACOS_BUNDLE_ID=

# --- Firebase Windows ---
FIREBASE_WINDOWS_API_KEY=
FIREBASE_WINDOWS_APP_ID=
FIREBASE_WINDOWS_PROJECT_ID=
FIREBASE_WINDOWS_AUTH_DOMAIN=
FIREBASE_WINDOWS_STORAGE_BUCKET=
FIREBASE_WINDOWS_MESSAGING_SENDER_ID=
