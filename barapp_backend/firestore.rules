rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // HELPERS
    // ===============================================================
    function isLoggedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isLoggedIn() && (
        request.auth.uid == 'TpOkGBVXlLZVSQhfCdCrZ6R82g42' || 
        request.auth.uid == 'okkS6brpDKg9FYkOqYp9t5OfPTv2'
      );
    }

    // ===============================================================
    // USUARIOS Y SUS SUBCOLECCIONES
    // ===============================================================
    match /usuarios/{userId} {
      // Permitir lectura a usuarios logueados (necesario para barPoints, reputacion, etc)
      allow get: if isLoggedIn();
      allow list: if isLoggedIn(); 
      
      // barPoints: el cliente solo puede DISMINUIR (canje), nunca aumentar.
      // Los aumentos los hace la Cloud Function onOrderDelivered (Admin SDK).
      allow create: if (isOwner(userId) || isSuperAdmin())
        && (!('barPoints' in request.resource.data) || request.resource.data.barPoints == 0);
      allow update: if (isOwner(userId) || isSuperAdmin())
        && (!('barPoints' in request.resource.data)
            || request.resource.data.barPoints <= resource.data.get('barPoints', 0));
      allow delete: if isOwner(userId) || isSuperAdmin();

      match /chats/{chatId} {
        allow read: if isOwner(userId); 
        allow write: if isLoggedIn(); 
      }

      match /blockedUsers/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      match /blockedBy/{docId} {
        allow read: if isOwner(userId);
        allow write: if isLoggedIn(); 
      }

      match /silenciados/{targetId} {
        allow write: if isOwner(userId);
        allow read: if isOwner(userId) || request.auth.uid == targetId;
      }

      // Subcolecciones para cupones
      match /mis_cupones/{cuponId} {
        allow read: if isOwner(userId) || isLoggedIn(); // Los bares pueden leer para validar
        allow write: if isOwner(userId) || isSuperAdmin();
      }

      match /cupones_usados/{cuponId} {
        allow read: if isOwner(userId) || isLoggedIn(); // Los bares pueden leer para validar
        allow write: if isOwner(userId) || isSuperAdmin();
      }

      // RUTA B: Calificaciones que los bares dejan sobre el cliente
      match /reputacion_recibida/{placeId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isLoggedIn();
      }

      // Historial de BarPoints: el usuario puede crear solo DÉBITOS (monto <= 0) para canjes.
      // Los CRÉDITOS (monto > 0) solo los escribe la Cloud Function onOrderDelivered (Admin SDK).
      match /historial_puntos/{movId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        // máx débito posible = -500 (cap total de BarPoints); evita spam de logs falsos
        allow create: if isOwner(userId)
            && request.resource.data.get('monto', 0) <= 0
            && request.resource.data.get('monto', 0) >= -500;
        allow update, delete: if false;
      }
    }

    // ===============================================================
    // COLLECTION 'users' (legacy — mantener compatibilidad)
    // ===============================================================
    match /users/{userId} {
      allow get: if isLoggedIn();
      allow list: if isLoggedIn();
      // barPoints: misma protección que usuarios
      allow create: if (isOwner(userId) || isSuperAdmin())
        && (!('barPoints' in request.resource.data) || request.resource.data.barPoints == 0);
      allow update: if (isOwner(userId) || isSuperAdmin())
        && (!('barPoints' in request.resource.data)
            || request.resource.data.barPoints <= resource.data.get('barPoints', 0));
      allow delete: if isOwner(userId) || isSuperAdmin();

      match /chats/{chatId} {
        allow read: if isOwner(userId); 
        allow write: if isLoggedIn(); 
      }

      match /blockedUsers/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      match /blockedBy/{docId} {
        allow read: if isOwner(userId);
        allow write: if isLoggedIn(); 
      }

      match /silenciados/{targetId} {
        allow write: if isOwner(userId);
        allow read: if isOwner(userId) || request.auth.uid == targetId;
      }

      match /mis_cupones/{cuponId} {
        allow read: if isOwner(userId) || isLoggedIn();
        allow write: if isOwner(userId) || isSuperAdmin();
      }

      match /cupones_usados/{cuponId} {
        allow read: if isOwner(userId) || isLoggedIn();
        allow write: if isOwner(userId) || isSuperAdmin();
      }

      // RUTA B (legacy): misma regla que en 'usuarios'
      match /reputacion_recibida/{placeId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isLoggedIn();
      }

      // Historial de BarPoints (legacy): mismo criterio que usuarios
      match /historial_puntos/{movId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        // máx débito posible = -500 (cap total de BarPoints); evita spam de logs falsos
        allow create: if isOwner(userId)
            && request.resource.data.get('monto', 0) <= 0
            && request.resource.data.get('monto', 0) >= -500;
        allow update, delete: if false;
      }
    }

    // ===============================================================
    // PLACES (NEGOCIOS)
    // ===============================================================
    match /places/{placeId} {
      allow read: if true;
      allow write: if isLoggedIn() || isSuperAdmin();

      match /menu/{item} {
        allow read: if true;
        allow write: if isLoggedIn();
      }

      match /orders/{orderId} {
        allow create: if isLoggedIn();
        allow read: if isLoggedIn();
        allow update: if isLoggedIn();
      }

      // RUTA A: Calificaciones que los clientes dejan sobre el bar
      match /ratings_recibidas/{ratingId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn();
      }

      // Subcolecciones explícitas (sin wildcard /{document=**})
      match /mesas/{mesaId} {
        allow read, write: if isLoggedIn();

        match /cuenta_items/{itemId} {
          allow read, write: if isLoggedIn();
        }
      }

      match /ventas/{ventaId} {
        allow read, write: if isLoggedIn();
      }

      match /gastos/{gastoId} {
        allow read, write: if isLoggedIn();
      }

      match /caja_sesiones/{sesionId} {
        allow read, write: if isLoggedIn();
      }

      match /reservas/{reservaId} {
        allow read, write: if isLoggedIn();
      }

      match /staff/{staffId} {
        allow read, write: if isLoggedIn();
      }

      match /asistencias/{asistenciaId} {
        allow read, write: if isLoggedIn();
      }

      match /proveedores/{proveedorId} {
        allow read, write: if isLoggedIn();
      }

      match /ratings/{ratingId} {
        allow read, write: if isLoggedIn();
      }

      match /comandas/{comandaId} {
        allow read, write: if isLoggedIn();
      }

      match /movimientos_caja_fuerte/{movId} {
        allow read, write: if isLoggedIn();
      }

      match /followers/{followerId} {
        allow read, write: if isLoggedIn();
      }
    }

    // ===============================================================
    // CUPONES MAESTROS (Superadmin)
    // ===============================================================
    match /cupones_maestros/{cuponId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin();
    }

    // ===============================================================
    // OTROS (CHATS, REPORTES, EVENTOS, ETC)
    // ===============================================================
    match /chats/{document=**} {
      allow read, write: if isLoggedIn();
    }

    match /reports/{reportId} {
      allow create: if isLoggedIn();
      allow read, delete: if isSuperAdmin();
    }

    match /notification_limits/{docId} {
      allow read: if isLoggedIn();
      allow write: if isSuperAdmin();
    }
    
    match /comunidad/{document=**} {
      allow read, write: if isLoggedIn();
    }

    match /stories/{document=**} {
      allow read, write: if isLoggedIn();
    }

    match /events/{document=**} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ===============================================================
    // COLLECTION GROUPS
    // ===============================================================
    match /{path=**}/orders/{orderId} {
      allow read: if isLoggedIn();
      allow update: if isLoggedIn();
    }

    match /{path=**}/delivery_orders/{orderId} {
      allow read, write: if isLoggedIn();
    }
    
    match /{path=**}/reservas/{reservaId} {
      allow read, write: if isLoggedIn();
    }

    match /{path=**}/ratings/{ratingId} {
      allow read, write: if true;
    }
  }
}
